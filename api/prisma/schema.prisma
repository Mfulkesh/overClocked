// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── User (Privy-linked) ─────────────────────────────────────────────────────
model User {
  id            String   @id @default(uuid())
  privyId       String   @unique @default("") // Privy DID
  walletAddress String?  @unique // Embedded or external wallet
  email         String?  @unique
  twitterHandle String?
  createdAt     DateTime @default(now())

  org       Org?
  donations Donation[]
}

// ── Organisation ────────────────────────────────────────────────────────────
// Covers: student orgs, NGOs, DAOs, community groups, charities
model Org {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  name          String
  description   String?
  category      OrgCategory @default(OTHER)
  websiteUrl    String?
  twitterHandle String?
  logoUrl       String? // S3 key

  // Verification docs (S3 keys)
  docUrls String[]

  // On-chain PDA address for this org
  onchainPda String? @unique
  // SHA-256(gstin uppercase) used in on-chain checks.
  onchainGstinHash String?

  // GST profile captured at org onboarding.
  gstin                String? @unique
  gstinVerified        Boolean @default(false)
  gstinLegalName       String?
  gstinTradeName       String?
  gstinState           String?
  gstinStateCode       String?
  gstinStatus          String?
  gstinRegistrationDate String?
  gstinVerifiedAt      DateTime?
  gstinLastCheckedAt   DateTime?

  // Reputation (mirrored from on-chain; updated by Helius webhook)
  campaignsCreated    Int    @default(0)
  campaignsCompleted  Int    @default(0)
  campaignsFailed     Int    @default(0)
  totalRaisedLamports BigInt @default(0)
  completionRateBps   Int    @default(0)

  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  campaigns Campaign[]
}

enum OrgCategory {
  STUDENT_ORG
  NGO
  DAO
  COMMUNITY
  CHARITY
  OPEN_SOURCE
  OTHER
}

// ── Campaign ────────────────────────────────────────────────────────────────
model Campaign {
  id    String @id @default(uuid())
  orgId String
  org   Org    @relation(fields: [orgId], references: [id])

  title       String
  description String
  category    String?
  bannerUrl   String? // S3 key
  tags        String[]

  // On-chain references
  onchainProjectPda String? @unique
  onchainVaultPda   String? @unique
  projectIdBytes    String? // hex of the 32-byte project_id seed

  // Goal & state (mirrored from chain)
  hasGoal           Boolean       @default(true)
  totalGoalLamports BigInt        @default(0)
  raisedLamports    BigInt        @default(0)
  state             CampaignState @default(ACTIVE)

  // Prefront config
  prefrontLamports BigInt @default(0)
  prefrontTranches Int    @default(0)
  prefrontClaimed  Int    @default(0)

  // Yield policy (0=None, 1=Low5, 2=Mid8, 3=High12)
  yieldPolicy Int @default(0)

  deadline  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  milestones    Milestone[]
  donations     Donation[]
  yieldAccruals YieldAccrual[]
}

enum CampaignState {
  ACTIVE
  COMPLETED
  FAILED
  FROZEN
}

// ── Milestone ───────────────────────────────────────────────────────────────
model Milestone {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  index       Int // 0-based, matches on-chain index
  title       String
  description String?

  // DPR Phase label — shown in UI as "Phase 1: Venue & Logistics"
  dprPhaseLabel String? // optional human label for this milestone/DPR phase

  // Release config
  amountLamports BigInt @default(0)
  releasePctBps  Int    @default(0)

  // Proof
  proofUri  String? // on-chain URI (S3 key) set after submission
  proofNote String? // creator's explanation

  // Voting config
  thresholdBps     Int @default(5100)
  quorumBps        Int @default(1000)
  // Voting window set by creator at proof submission. Min 48h (172800s), Max 7d (604800s)
  votingWindowSecs Int @default(172800) // 48h default

  deadline      DateTime?
  state         MilestoneState @default(PENDING)
  revisionCount Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proof   MilestoneProof?
  updates MilestoneUpdate[]
}

// ── MilestoneProof (GST-verified spend evidence) ─────────────────────────────
// Created when a creator submits proof for a milestone.
// Stores a chain of verified invoices; prev_proof_hash links to the previous milestone's proof
// forming a tamper-evident audit trail (like git commits for money).
model MilestoneProof {
  id          String    @id @default(uuid())
  milestoneId String    @unique
  milestone   Milestone @relation(fields: [milestoneId], references: [id])

  // GST verification
  gstin                String? // 15-char GSTIN of the vendor
  gstinVerified        Boolean @default(false)
  vendorLegalName      String? // returned by GST API, not entered by creator
  vendorState          String? // state code from GST API
  isUnregisteredVendor Boolean @default(false) // true for vendors below GST threshold

  // Invoice details
  invoiceNumber      String?
  invoiceAmountPaise BigInt? // full invoice amount in paise (must be >= release amount)
  invoiceS3Key       String? // S3 object key for the uploaded invoice PDF/image
  invoiceHash        String // hex-encoded SHA-256 of the invoice file (for tamper detection)

  // Proof-of-History chain
  // Each proof hashes the previous proof's invoiceHash — creates an ordered chain
  prevProofHash   String? // invoiceHash of the immediately preceding MilestoneProof, null for first
  onchainProofUri String? // S3 JSON URI stored on Solana via submit_milestone_proof

  submittedAt DateTime @default(now())
}

// ── MilestoneUpdate (DPR Progress Timeline) ───────────────────────────────────
// Creator posts updates any time during a milestone — like git commits.
// Visible to donors as a live activity feed showing "what we did, when".
model MilestoneUpdate {
  id          String    @id @default(uuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id])

  type        MilestoneUpdateType @default(PROGRESS)
  title       String
  description String?
  mediaUrls   String[] // S3 keys for photos, videos, docs

  // Creator signs a hash of this update to prove authenticity
  creatorWallet String?
  contentHash   String? // SHA-256 of title+description — stored for tamper detection

  postedAt  DateTime @default(now())
  createdAt DateTime @default(now())
}

enum MilestoneUpdateType {
  PROGRESS // General update ("We booked the venue")
  EXPENSE // Money spent ("Paid ₹20,000 to AV vendor") — should link to proof
  PHOTO // Visual update ("Site visit photos")
  ANNOUNCEMENT // Important announcement ("Event date changed")
  COMPLETION // Marks end of milestone work before formal proof submission
}

enum MilestoneState {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

// ── Donation ────────────────────────────────────────────────────────────────
model Donation {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])

  // For anonymous donations (wallet-only, no User record)
  donorWallet String?

  amountLamports BigInt
  amountInr      Int? // Set for UPI donations
  paymentType    PaymentType @default(SOL)

  // UPI flow
  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique

  // On-chain
  txSignature String? @unique
  confirmed   Boolean @default(false)

  createdAt DateTime @default(now())
}

enum PaymentType {
  SOL
  UPI
}

// ── Yield Accrual (mock) ────────────────────────────────────────────────────
model YieldAccrual {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  yieldLamports BigInt // amount accrued this period
  periodDate    DateTime // which day this represents
  yieldRateBps  Int // rate used (500, 800, or 1200)

  createdAt DateTime @default(now())
}
